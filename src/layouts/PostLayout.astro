---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import { withBase } from '../lib/url';

interface SeriesNav {
  title: string;
  order: number;
  parts: { slug: string; title: string; order: number }[];
}

interface Props {
  post: CollectionEntry<'blog'>;
  minutesRead?: number;
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
  series?: SeriesNav | null;
}
const { post, minutesRead, prev, next, series } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

// Build-time generated social card for this post (src/pages/og/[...route].ts).
const ogImage = withBase(`/og/${post.id}.png`);
---

<BaseLayout title={title} description={description} image={ogImage} article={true}>
  <article>
    <header class="mb-8 border-b border-border pb-8">
      <a href={withBase('/blog')} class="font-mono text-xs text-accent hover:underline">← All posts</a>
      <h1 class="mt-4 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-lg text-muted">{description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-faint">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {minutesRead ? <span>· {minutesRead} min read</span> : null}
        {updatedDate ? <span>· updated {fmt(updatedDate)}</span> : null}
      </div>
      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {tags.map((t) => (
              <Tag name={t} href={`/tags/${t}`} />
            ))}
          </div>
        )
      }
    </header>

    {
      series && (
        <aside class="mb-8 rounded-lg border border-border p-4" aria-label="Series">
          <p class="font-mono text-xs text-faint">
            // series · part {series.order} of {series.parts.length}
          </p>
          <p class="mt-1 text-sm font-medium">{series.title}</p>
          <details class="mt-2">
            <summary class="cursor-pointer select-none font-mono text-xs text-accent hover:underline">
              all parts
            </summary>
            <ol class="mt-3 space-y-1.5">
              {series.parts.map((part) => (
                <li class="flex items-baseline gap-2.5 text-sm">
                  <span class="shrink-0 font-mono text-xs text-faint">
                    {String(part.order).padStart(2, '0')}
                  </span>
                  {part.slug === post.id ? (
                    <span class="font-medium text-accent">{part.title} ← this one</span>
                  ) : (
                    <a href={withBase(`/blog/${part.slug}`)} class="transition-colors hover:text-accent">
                      {part.title}
                    </a>
                  )}
                </li>
              ))}
            </ol>
          </details>
        </aside>
      )
    }

    <div class="prose">
      <slot />
    </div>
  </article>

  {
    (prev || next) && (
      <nav class="mt-14 grid gap-3 border-t border-border pt-8 sm:grid-cols-2" aria-label="More posts">
        {prev ? (
          <a
            href={withBase(`/blog/${prev.slug}`)}
            class="group rounded-lg border border-border p-4 transition-colors hover:border-accent"
          >
            <span class="font-mono text-xs text-faint">← Previous</span>
            <span class="mt-1 block text-sm font-medium group-hover:text-accent">{prev.title}</span>
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a
            href={withBase(`/blog/${next.slug}`)}
            class="group rounded-lg border border-border p-4 text-right transition-colors hover:border-accent"
          >
            <span class="font-mono text-xs text-faint">Next →</span>
            <span class="mt-1 block text-sm font-medium group-hover:text-accent">{next.title}</span>
          </a>
        ) : (
          <span />
        )}
      </nav>
    )
  }
</BaseLayout>

<script>
  // Add a copy button to each code block after render.
  document.querySelectorAll<HTMLPreElement>('.prose pre').forEach((pre) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'copy-btn';
    btn.textContent = 'copy';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    wrapper.appendChild(btn);

    btn.addEventListener('click', async () => {
      const code = pre.querySelector<HTMLElement>('code')?.innerText ?? pre.innerText;
      try {
        await navigator.clipboard.writeText(code);
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = 'copy'), 1500);
      } catch {
        btn.textContent = 'error';
        setTimeout(() => (btn.textContent = 'copy'), 1500);
      }
    });
  });
</script>
