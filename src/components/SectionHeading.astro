---
/**
 * Numbered section heading with a trailing rule — the shared motif for
 * top-level sections across pages. Renders as `01 — LABEL ————`.
 */
interface Props {
  index?: string;
  label: string;
  class?: string;
}
const { index, label, class: className = '' } = Astro.props;
---

<h2 class:list={['flex items-center gap-3 font-mono text-xs uppercase tracking-[0.25em] text-faint', className]}>
  {index && <span class="text-accent">{index}</span>}
  <span>{label}</span>
  <span class="h-px min-w-8 flex-1 bg-border" aria-hidden="true"></span>
</h2>
