---
import { site } from '../data/site';
import { withBase } from '../lib/url';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div
    class="mx-auto flex max-w-3xl flex-col items-center justify-between gap-4 px-4 py-8 sm:flex-row sm:px-6"
  >
    <p class="font-mono text-xs text-faint">
      © {year} {site.name} · <a href={withBase('/rss.xml')} class="transition-colors hover:text-accent">rss</a> · built with Astro
    </p>
    <SocialLinks />
  </div>
</footer>
