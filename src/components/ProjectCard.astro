---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const isPublic = project.status === 'public';
const Tag = project.href ? 'a' : 'div';
---

<Tag
  href={project.href}
  target={project.href ? '_blank' : undefined}
  rel={project.href ? 'noopener' : undefined}
  class:list={[
    'group flex h-full flex-col rounded-xl border border-border bg-surface p-5 transition-colors',
    project.href ? 'hover:border-accent' : '',
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-base font-semibold leading-snug group-hover:text-accent">
      {project.name}
    </h3>
    <span
      class:list={[
        'shrink-0 rounded-full px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide',
        isPublic
          ? 'bg-accent-soft text-accent'
          : 'border border-border text-faint',
      ]}
    >
      {isPublic ? 'Public' : 'In progress'}
    </span>
  </div>

  <p class="mt-2 flex-1 text-sm text-muted">{project.blurb}</p>

  <ul class="mt-4 flex flex-wrap gap-1.5">
    {
      project.tech.map((t) => (
        <li class="rounded border border-border px-1.5 py-0.5 font-mono text-[11px] text-faint">
          {t}
        </li>
      ))
    }
  </ul>

  {
    project.href && (
      <span class="mt-4 inline-flex items-center gap-1 font-mono text-xs text-accent">
        View on GitHub
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    )
  }
</Tag>
