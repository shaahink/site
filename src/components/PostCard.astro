---
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  minutesRead?: number;
}
const { title, description, href, pubDate, minutesRead } = Astro.props;
const resolvedHref = withBase(href);

const dateLabel = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
const isoDate = pubDate.toISOString();
---

<article class="group border-b border-border py-5 first:pt-0">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-faint">
    <time datetime={isoDate}>{dateLabel}</time>
    {minutesRead ? <span aria-hidden="true">·</span> : null}
    {minutesRead ? <span>{minutesRead} min</span> : null}
  </div>

  <h3 class="mt-1.5 text-lg font-semibold leading-snug">
    <a href={resolvedHref} class="transition-colors group-hover:text-accent">{title}</a>
  </h3>

  <p class="mt-1.5 max-w-2xl text-sm leading-relaxed text-muted">{description}</p>
</article>
