---
import Tag from './Tag.astro';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  minutesRead?: number;
  tags?: string[];
}
const { title, description, href, pubDate, minutesRead, tags = [] } = Astro.props;
const resolvedHref = withBase(href);

const dateLabel = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const isoDate = pubDate.toISOString();
---

<article
  class="group rounded-xl border border-border bg-surface p-5 transition-colors hover:border-accent"
>
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-faint">
    <time datetime={isoDate}>{dateLabel}</time>
    {minutesRead ? <span>· {minutesRead} min read</span> : null}
  </div>

  <h3 class="mt-2 text-lg font-semibold leading-snug">
    <a href={resolvedHref} class="transition-colors group-hover:text-accent">{title}</a>
  </h3>

  <p class="mt-1.5 text-sm text-muted">{description}</p>

  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((t) => (
          <Tag name={t} href={`/tags/${t}`} />
        ))}
      </div>
    )
  }
</article>
