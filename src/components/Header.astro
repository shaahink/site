---
import { site, nav } from '../data/site';
import { withBase } from '../lib/url';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => {
  const full = withBase(href);
  return href === '/' ? path === full || path === `${full}/` : path === full || path.startsWith(`${full}/`);
};
---

<header
  class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur supports-[backdrop-filter]:bg-bg/70"
>
  <div class="mx-auto flex h-14 max-w-3xl items-center justify-between px-4 sm:px-6">
    <a href={withBase('/')} class="group flex items-center gap-2 font-mono text-sm font-semibold">
      <span
        class="grid h-7 w-7 place-items-center rounded-md bg-accent text-[13px] font-bold text-accent-contrast"
        aria-hidden="true">SK</span
      >
      <span class="text-fg transition-colors group-hover:text-accent">{site.name}</span>
    </a>

    <nav class="flex items-center gap-1" aria-label="Primary">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                class:list={[
                  'rounded-md px-3 py-1.5 text-sm transition-colors hover:text-accent',
                  isActive(item.href) ? 'text-fg font-medium' : 'text-muted',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="ml-1"><ThemeToggle /></div>
    </nav>
  </div>

  <!-- Compact nav for narrow screens -->
  <nav class="border-t border-border sm:hidden" aria-label="Primary mobile">
    <ul class="mx-auto flex max-w-3xl items-center justify-around px-2 py-1">
      {
        nav.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              class:list={[
                'block rounded-md px-3 py-1.5 text-sm transition-colors hover:text-accent',
                isActive(item.href) ? 'text-fg font-medium' : 'text-muted',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
