---

<ul class={`flex items-center gap-1 ${className}`}>
  {
    socials.map((s) => (
      <li>
        <a
          href={s.href}
          class="grid h-9 w-9 place-items-center rounded-md border border-transparent text-muted transition-colors hover:border-border hover:text-accent"
          aria-label={s.label}
          title={s.label}
          rel={s.href.startsWith('http') ? 'me noopener' : undefined}
          target={s.href.startsWith('http') ? '_blank' : undefined}
        >
          <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={paths[s.icon]} />
          </svg>
        </a>
      </li>
    ))
  }
</ul>
