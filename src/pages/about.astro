---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';
import { withBase } from '../lib/url';

const pdfHref = withBase('/cv/Shahin-Kiassat-CV.pdf');

const facts = [
  { key: 'location', value: 'London, UK · British citizen' },
  { key: 'day stack', value: 'C# / .NET · TypeScript / Angular · Python' },
  { key: 'platforms', value: 'Azure · GCP · Docker · IaC (Bicep, Terraform)' },
  { key: 'currently', value: 'agent orchestration · code-graph tooling · a trading engine' },
];

const eras = [
  {
    period: '2015 – 2022',
    title: 'Maps',
    body: 'A geospatial software company, twice — with an adventure in between. Transport-accessibility analysis used by councils and planners: multi-tenant GIS platforms, a queue-management and deferred-results system built test-first, single sign-on with IdentityServer. My first long exposure to software that outlives its authors, and to performance work where "slow" means a planner waits an hour instead of a minute.',
  },
  {
    period: '2017 – 2019',
    title: 'Parcels',
    body: 'A logistics SaaS platform: real-time courier management at high volume, with the uptime expectations that come from vans on the road and money on the line. Multi-tenant architecture, token auth, a Xamarin app for drivers. Where I learned that "distributed system" is not an aesthetic — it\'s what happens when field devices lose signal mid-transaction.',
  },
  {
    period: '2022 – 2023',
    title: 'Markets',
    body: "An algorithmic trading firm: core microservices for the trading platform, backtesting frameworks, ML prototypes in Python for signal validation. This is where the itch behind Shamshir started — the uncomfortable gap between a strategy that backtests beautifully and code you would actually trust with a funded account.",
  },
  {
    period: '2023 – 2024',
    title: 'Pipelines',
    body: 'A data-platform consultancy on GCP: high-throughput .NET APIs processing 500K+ transactions a day, long-running batch jobs migrated to event-driven flows over RabbitMQ, infrastructure as code with Terraform. A masterclass in the difference between "it works" and "it works at 3am under load with nobody watching".',
  },
  {
    period: '2024 – 2026',
    title: 'Threat intel',
    body: 'The formative one. Sole engineer at an early-stage AI cybersecurity startup — the architecture, the backend, the Angular front-end, the Azure infrastructure, and the releases were all mine. Event-driven ingestion pipelines swallowing everything from firewall logs to 50GB data dumps, a conversational threat-intelligence UI, and a RAG engine integrated end to end: session management, prompt construction, context extraction, vector search. Working that close to an LLM every day made one thing obvious — the model is rarely the bottleneck; the context you feed it and the verification around it are. That conviction became the through-line of everything I now build.',
  },
];
---

<BaseLayout
  title="About"
  description={`About ${site.name} — software engineer in London. The story behind ten years of maps, parcels, markets, pipelines, and threat intelligence.`}
>
  <header class="border-b border-border pb-6">
    <p class="font-mono text-xs tracking-wide text-accent">// about</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Shahin Kiassat</h1>
    <p class="mt-4 max-w-2xl leading-relaxed text-muted">
      The formal summary says ten-plus years of full-stack .NET across fintech, geospatial, and
      cybersecurity. The honest version: I like being handed a system that has to work — a courier
      network, a trading account with hard drawdown rules, a threat-intelligence pipeline — and
      owning it end to end until it does.
    </p>
  </header>

  <!-- The short version -->
  <section class="mt-12">
    <SectionHeading index="01" label="The short version" />
    <dl class="mt-5 max-w-2xl rounded-lg border border-border bg-surface p-5 font-mono text-sm">
      {
        facts.map((f) => (
          <div class="flex flex-col gap-x-6 py-1.5 sm:flex-row">
            <dt class="w-28 shrink-0 text-faint">{f.key}:</dt>
            <dd class="text-muted">{f.value}</dd>
          </div>
        ))
      }
      <div class="flex flex-col gap-x-6 py-1.5 sm:flex-row">
        <dt class="w-28 shrink-0 text-faint">contact:</dt>
        <dd class="flex flex-wrap gap-x-4 gap-y-1">
          <a href={`mailto:${site.email}`} class="text-accent hover:underline">email</a>
          <a href="https://github.com/shaahink" target="_blank" rel="me noopener" class="text-accent hover:underline">github</a>
          <a href={pdfHref} download class="text-accent hover:underline">cv.pdf</a>
        </dd>
      </div>
    </dl>
  </section>

  <!-- The long version -->
  <section class="mt-14">
    <SectionHeading index="02" label="How I got here" />
    <p class="mt-5 max-w-2xl text-sm leading-relaxed text-muted">
      Told as eras rather than job titles. Employers here are described by what they do, not who
      they are — the PDF has the formal version.
    </p>
    <div class="mt-8 space-y-9">
      {
        eras.map((era) => (
          <article class="relative border-l border-border pl-6">
            <span class="absolute -left-[5px] top-2 h-2.5 w-2.5 rounded-full bg-accent" aria-hidden="true" />
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
              <h3 class="font-mono text-base font-semibold">{era.title}</h3>
              <span class="font-mono text-xs text-faint">{era.period}</span>
            </div>
            <p class="mt-2 max-w-2xl text-[0.95rem] leading-relaxed text-muted">{era.body}</p>
          </article>
        ))
      }
    </div>
    <p class="mt-9 max-w-2xl text-sm leading-relaxed text-faint">
      Before all that (2011–2015): ASP.NET and WPF, early single-page apps in AngularJS, and the
      general apprenticeship of shipping software people paid for.
    </p>
  </section>

  <!-- Off hours -->
  <section class="mt-14">
    <SectionHeading index="03" label="Off hours" />
    <p class="mt-5 max-w-2xl leading-relaxed text-muted">
      Most of my spare cycles go into <a href={withBase('/projects')} class="text-accent hover:underline">the lab</a> —
      an orchestrator that runs coding agents without believing them, a code graph that cites its
      sources, and a trading engine built as a pure function. Different domains, same instinct:
      if a system can't prove what it did, it didn't do it. The
      <a href={withBase('/blog')} class="text-accent hover:underline">writing</a> is where those
      ideas get argued out.
    </p>
  </section>

  <!-- Formalities -->
  <section class="mt-14">
    <SectionHeading index="04" label="Formalities" />
    <p class="mt-5 max-w-2xl text-sm leading-relaxed text-muted">
      If you're hiring, the
      <a href={pdfHref} download class="text-accent hover:underline">CV PDF</a> is the formal
      artefact — dates, bullet points, the usual. If you want to know how I actually think about
      building software, the writing and the projects are more honest. Either way,
      <a href={`mailto:${site.email}`} class="text-accent hover:underline">email works</a>.
    </p>
  </section>
</BaseLayout>
