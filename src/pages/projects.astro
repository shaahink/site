---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Projects"
  description="The lab — an agent orchestrator that verifies instead of trusting, a provenance-carrying code graph for .NET, and a deterministic trading engine."
>
  <header class="border-b border-border pb-6">
    <p class="font-mono text-xs tracking-wide text-accent">// the lab</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Projects</h1>
    <p class="mt-3 max-w-2xl leading-relaxed text-muted">
      Three systems, one obsession: software that produces evidence for its own behaviour. Each is
      written up below the way I'd explain it over coffee — the itch, the core idea, and the parts
      that were genuinely fun to build. All three live somewhere between “works on my machine” and
      “ready for yours”; links appear as they're published.
    </p>
  </header>

  <div class="mt-4">
    {
      projects.map((p, i) => (
        <article id={p.slug} class="scroll-mt-20 border-b border-border py-10 last:border-b-0">
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
            <span class="font-mono text-xs text-accent">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="font-mono text-xl font-semibold tracking-tight">{p.name}</h2>
            <span class="inline-flex items-center gap-1.5 font-mono text-[11px] text-faint">
              <span
                class:list={[
                  'inline-block h-1.5 w-1.5 rounded-full bg-accent',
                  p.status === 'building' ? 'status-pulse' : '',
                ]}
                aria-hidden="true"
              />
              {p.status}
            </span>
          </div>

          <p class="mt-3 max-w-2xl font-medium leading-relaxed">{p.oneLiner}</p>

          <div class="mt-4 max-w-2xl space-y-4 text-[0.95rem] leading-relaxed text-muted">
            {p.story.map((para) => (
              <p>{para}</p>
            ))}
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2">
            <p class="font-mono text-xs text-faint">{p.stack}</p>
            {p.href && (
              <a
                href={p.href}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1 font-mono text-xs text-accent hover:underline"
              >
                {p.linkNote ?? 'view on GitHub'}
                <svg
                  class="h-3 w-3"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            )}
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
