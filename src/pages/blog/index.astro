---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Tag from '../../components/Tag.astro';
import { getPostSummaries, getAllTags } from '../../lib/posts';

const posts = await getPostSummaries();
const tags = await getAllTags();
---

<BaseLayout
  title="Writing"
  description="Notes from the workshop — running agents unattended, tracing code through indirection, replaying markets, and the systems habits behind all three."
>
  <header class="border-b border-border pb-6">
    <p class="font-mono text-xs tracking-wide text-accent">// writing</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Notes from the workshop</h1>
    <p class="mt-3 max-w-2xl leading-relaxed text-muted">
      Ideas argued out in public — mostly the ones behind the projects: verifying agents instead of
      trusting them, tracing code through indirection, and keeping systems replayable.
    </p>
    {
      tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-1.5">
          {tags.map((t) => (
            <Tag name={t} href={`/tags/${t}`} />
          ))}
        </div>
      )
    }
  </header>

  {
    posts.length > 0 ? (
      <div class="mt-4">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.slug}`}
            pubDate={post.data.pubDate}
            minutesRead={post.minutesRead}
          />
        ))}
      </div>
    ) : (
      <p class="mt-8 text-muted">No posts yet — check back soon.</p>
    )
  }
</BaseLayout>
