---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Tag from '../../components/Tag.astro';
import { getPostSummaries, getAllTags } from '../../lib/posts';

const posts = await getPostSummaries();
const tags = await getAllTags();
---

<BaseLayout
  title="Blog"
  description="Notes on .NET, distributed systems, developer tooling, and applied AI/LLM engineering."
>
  <header class="border-b border-border pb-6">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Notes on .NET and distributed systems, developer tooling, and building with LLMs on real
      codebases.
    </p>
    {
      tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-1.5">
          {tags.map((t) => (
            <Tag name={t} href={`/tags/${t}`} />
          ))}
        </div>
      )
    }
  </header>

  {
    posts.length > 0 ? (
      <div class="mt-8 grid gap-4">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.slug}`}
            pubDate={post.data.pubDate}
            minutesRead={post.minutesRead}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="mt-8 text-muted">No posts yet — check back soon.</p>
    )
  }
</BaseLayout>
